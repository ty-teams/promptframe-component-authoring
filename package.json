{
  "name": "promptframe-component-authoring",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build",
    "lint": "pnpm -r --filter './packages/*' lint",
    "lint:public": "node scripts/public-export-lint.mjs",
    "test": "pnpm -r --filter './packages/*' test",
    "test:previewroot-geometry": "pnpm --filter create-promptframe-component test:previewroot-geometry",
    "pack:dry-run": "pnpm -r --filter './packages/*' build && pnpm -r --filter './packages/*' exec npm pack --dry-run --json"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1"
  }
}
