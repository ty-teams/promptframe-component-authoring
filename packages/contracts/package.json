{
  "name": "@promptframe/contracts",
  "version": "0.1.22",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./security-evaluator": {
      "import": "./dist/security-policy-evaluator.js",
      "types": "./dist/security-policy-evaluator.d.ts"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ty-teams/promptframe-component-authoring.git",
    "directory": "packages/contracts"
  },
  "bugs": {
    "url": "https://github.com/ty-teams/promptframe-component-authoring/issues"
  },
  "homepage": "https://github.com/ty-teams/promptframe-component-authoring#readme",
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "test": "pnpm build && node --test test/*.test.mjs",
    "pack:dry-run": "pnpm build && npm pack --dry-run --json",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "typescript": "~5.7.0",
    "zod": "^3.24.0"
  }
}
